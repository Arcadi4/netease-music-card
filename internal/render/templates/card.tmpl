* { box-sizing: border-box; color:black; font-size: 0; font-family: 'PingFang SC', 'Helvetica Neue', 'Segoe UI', 'Microsoft YaHei', sans-serif !important; }
html, body { margin: 0; padding: 3px; }
p { margin: 0; padding: 0; }
img { margin: 0; padding: 0; }
.clear { clear: both; }
.card { display: inline-block; background: white; border-radius: 10px; text-align: center; box-shadow: gray 0 0 10px; overflow: hidden; }
